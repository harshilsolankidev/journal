<%- include('partials/head') %>
<%- include('partials/shell-start') %>

<main class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 sm:py-8 lg:px-10">
  <%- include('partials/flash') %>

  <!-- Hero -->
  <section class="panel panel-glow hero-mesh relative mb-8 overflow-hidden rounded-3xl p-8 sm:p-10 animate-fade-in">
    <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-indigo-500/25 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 left-10 h-48 w-48 rounded-full bg-violet-500/15 blur-3xl"></div>
    <div class="relative max-w-2xl">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full badge-accent px-3 py-1 text-xs font-medium">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-400"></span>
        </span>
        Welcome back
      </div>
      <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight text-gradient sm:text-5xl lg:text-[3.25rem]">
        Your reflection hub
      </h1>
      <p class="mt-4 text-base leading-relaxed text-secondary sm:text-lg">
        Track your mood, reflect on your day, and build a meaningful writing habit — all in one premium workspace.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/journals/new" class="btn-primary inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold">
          Start writing
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/journals" class="btn-secondary inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold">
          Browse journals
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="mb-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4 animate-stagger">
    <article class="stat-card panel rounded-2xl p-6">
      <div class="flex items-start justify-between">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-500/15 ring-1 ring-indigo-500/25">
          <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        </div>
        <span class="badge">All time</span>
      </div>
      <p class="mt-5 text-sm font-medium text-secondary">Total Entries</p>
      <p class="mt-1 text-4xl font-bold tabular-nums tracking-tight text-primary"><%= stats.totalEntries %></p>
      <p class="mt-2 text-xs text-muted"><%= stats.entriesThisWeek %> added this week</p>
    </article>

    <article class="stat-card panel rounded-2xl p-6">
      <div class="flex items-start justify-between">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-500/15 ring-1 ring-emerald-500/25">
          <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <span class="badge">Today</span>
      </div>
      <p class="mt-5 text-sm font-medium text-secondary">Written Today</p>
      <p class="mt-1 text-4xl font-bold tabular-nums tracking-tight text-gradient-accent"><%= stats.entriesToday %></p>
      <p class="mt-2 text-xs text-muted"><%= stats.entriesToday > 0 ? 'Keep the momentum going' : 'Start your first entry today' %></p>
    </article>

    <article class="stat-card panel rounded-2xl p-6">
      <div class="flex items-start justify-between">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-violet-500/15 ring-1 ring-violet-500/25">
          <svg class="h-5 w-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <span class="badge">7 days</span>
      </div>
      <p class="mt-5 text-sm font-medium text-secondary">This Week</p>
      <p class="mt-1 text-4xl font-bold tabular-nums tracking-tight text-primary"><%= stats.entriesThisWeek %></p>
      <p class="mt-2 text-xs text-muted">Entries in the last 7 days</p>
    </article>

    <article class="stat-card panel panel-glow rounded-2xl p-6">
      <div class="flex items-start justify-between">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-500/15 ring-1 ring-amber-500/25 text-xl">
          <%= stats.topMood ? stats.topMood.emoji : '✨' %>
        </div>
        <span class="badge-accent">Top mood</span>
      </div>
      <p class="mt-5 text-sm font-medium text-secondary">Dominant Mood</p>
      <p class="mt-1 text-2xl font-bold tracking-tight text-primary"><%= stats.topMood ? stats.topMood.label : 'None yet' %></p>
      <p class="mt-2 text-xs text-muted"><%= stats.topMoodCount > 0 ? stats.topMoodCount + ' entries' : 'Write to unlock insights' %></p>
    </article>
  </section>

  <!-- Mood + Recent -->
  <section class="grid gap-6 xl:grid-cols-5 animate-stagger">
    <article class="panel rounded-2xl p-6 sm:p-8 xl:col-span-2">
      <div class="mb-6 flex items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-semibold text-primary">Mood Overview</h2>
          <p class="mt-0.5 text-sm text-muted">Distribution across all entries</p>
        </div>
        <span class="badge"><%= stats.totalEntries %> total</span>
      </div>

      <% if (stats.totalEntries === 0) { %>
        <div class="empty-illustration flex flex-col items-center rounded-2xl border border-dashed border-white/[0.08] px-6 py-12 text-center">
          <div class="flex flex-wrap justify-center gap-2">
            <% stats.moods.forEach(function(m) { %>
              <span class="mood-chip rounded-xl px-3 py-2 text-lg opacity-40"><%= m.emoji %></span>
            <% }); %>
          </div>
          <p class="mt-5 text-sm font-medium text-secondary">No mood data yet</p>
          <p class="mt-1 text-xs text-muted">Your mood patterns will appear here after your first entry.</p>
          <a href="/journals/new" class="btn-primary mt-6 inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold">
            Write first entry
          </a>
        </div>
      <% } else { %>
        <ul class="space-y-5">
          <% const moodColors = { happy: 'from-amber-400 to-orange-500', grateful: 'from-emerald-400 to-teal-500', excited: 'from-orange-400 to-rose-500', neutral: 'from-slate-400 to-slate-500', anxious: 'from-violet-400 to-purple-500', sad: 'from-blue-400 to-indigo-500' }; %>
          <% stats.moods.forEach(function(m) { %>
            <% const count = stats.moodCounts[m.value] || 0; %>
            <% const pct = stats.totalEntries ? Math.round((count / stats.totalEntries) * 100) : 0; %>
            <li>
              <div class="mb-2 flex items-center justify-between text-sm">
                <span class="flex items-center gap-2.5 font-medium text-primary">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/[0.04] text-base ring-1 ring-white/[0.06]"><%= m.emoji %></span>
                  <%= m.label %>
                </span>
                <span class="tabular-nums text-muted"><%= count %> &middot; <%= pct %>%</span>
              </div>
              <div class="h-2.5 overflow-hidden rounded-full bg-white/[0.06] ring-1 ring-white/[0.04]">
                <div class="mood-bar-fill h-full rounded-full bg-gradient-to-r <%= moodColors[m.value] || 'from-indigo-400 to-violet-500' %>" style="--bar-width: <%= pct %>%"></div>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </article>

    <article class="panel rounded-2xl p-6 sm:p-8 xl:col-span-3">
      <div class="mb-6 flex items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-semibold text-primary">Recent Entries</h2>
          <p class="mt-0.5 text-sm text-muted">Your latest reflections at a glance</p>
        </div>
        <a href="/journals" class="text-sm font-medium text-accent transition hover:text-primary">View all &rarr;</a>
      </div>

      <% if (stats.recent.length === 0) { %>
        <div class="empty-illustration flex flex-col items-center rounded-2xl border border-dashed border-white/[0.08] px-6 py-14 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-500/10 text-3xl ring-1 ring-indigo-500/20">📔</div>
          <p class="mt-5 text-base font-medium text-secondary">Your journal is waiting</p>
          <p class="mt-2 max-w-xs text-sm text-muted">Create your first entry to see recent reflections, mood trends, and writing insights here.</p>
          <a href="/journals/new" class="btn-primary mt-7 inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold">
            Create first entry
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      <% } else { %>
        <ul class="divide-y divide-white/[0.06]">
          <% stats.recent.forEach(function(j) { %>
            <li class="group py-4 first:pt-0 last:pb-0">
              <a href="/journals/<%= j.id %>" class="-mx-2 block rounded-xl px-3 py-3 transition hover:bg-white/[0.03]">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <p class="truncate font-semibold text-primary group-hover:text-accent"><%= j.title %></p>
                    <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-muted"><%= j.content %></p>
                    <p class="mt-2.5 text-xs text-muted"><%= formatRelative(j.updatedAt) %></p>
                  </div>
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white/[0.04] text-lg ring-1 ring-white/[0.06]"><%= j.moodMeta.emoji %></span>
                </div>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </article>
  </section>
</main>

<%- include('partials/shell-end') %>
