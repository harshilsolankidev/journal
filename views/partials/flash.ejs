<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="mb-6 rounded-xl border px-4 py-3 text-sm font-medium <%= flash.type === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/50 dark:text-emerald-300' : 'border-red-200 bg-red-50 text-red-800 dark:border-red-900 dark:bg-red-950/50 dark:text-red-300' %>">
    <%= flash.message %>
  </div>
<% } %>
