<%- include('../partials/head') %>
<%- include('../partials/shell-start') %>

<main class="mx-auto flex min-h-[60vh] w-full max-w-lg flex-1 flex-col items-center justify-center px-4 py-16 text-center">
  <div class="relative animate-fade-in">
    <div class="pointer-events-none absolute inset-0 rounded-full bg-indigo-500/20 blur-3xl"></div>
    <p class="relative text-7xl font-bold text-gradient-accent">404</p>
  </div>
  <h1 class="mt-6 text-2xl font-bold text-primary">Page not found</h1>
  <p class="mt-3 max-w-sm text-sm text-muted"><%= message %></p>
  <a href="/" class="btn-primary mt-8 inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold">
    Go to Dashboard
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </a>
</main>

<%- include('../partials/shell-end') %>
