<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
  <%- include('../partials/flash') %>

  <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">My Journals</h1>
      <p class="mt-1 text-slate-600 dark:text-slate-400">Browse, search, and manage your entries.</p>
    </div>
    <a href="/journals/new" class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">New Entry</a>
  </header>

  <form action="/journals" method="GET" class="mb-8">
    <div class="relative">
      <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="search" name="q" value="<%= search %>" placeholder="Search by title, content, or mood..."
             class="w-full rounded-2xl border border-slate-200 bg-white py-3 pl-12 pr-4 dark:border-slate-700 dark:bg-slate-900 dark:text-white">
    </div>
    <% if (search) { %><p class="mt-2 text-sm text-slate-500">Results for &ldquo;<%= search %>&rdquo; &middot; <a href="/journals" class="text-brand-600">Clear</a></p><% } %>
  </form>

  <% if (journals.length === 0) { %>
    <section class="rounded-2xl border border-dashed border-slate-300 px-6 py-16 text-center dark:border-slate-700">
      <p class="text-5xl">📔</p>
      <h2 class="mt-4 text-xl font-semibold">No journals found</h2>
      <% if (!search) { %><a href="/journals/new" class="mt-6 inline-flex rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white">Create first entry</a><% } %>
    </section>
  <% } else { %>
    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% journals.forEach(function(j) { %>
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <div class="mb-3 flex items-start justify-between">
            <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-sm dark:bg-slate-800"><%= j.moodMeta.emoji %> <%= j.moodMeta.label %></span>
            <time class="text-xs text-slate-400"><%= formatRelative(j.updatedAt) %></time>
          </div>
          <h2 class="text-lg font-semibold"><a href="/journals/<%= j.id %>" class="hover:text-brand-600"><%= j.title %></a></h2>
          <p class="mt-2 line-clamp-3 text-sm text-slate-600 dark:text-slate-400"><%= j.content %></p>
          <div class="mt-4 flex gap-3 border-t border-slate-100 pt-4 dark:border-slate-800">
            <a href="/journals/<%= j.id %>" class="text-sm font-medium text-brand-600">Read</a>
            <a href="/journals/<%= j.id %>/edit" class="text-sm font-medium text-slate-600">Edit</a>
          </div>
        </article>
      <% }); %>
    </section>
  <% } %>
</main>

<%- include('../partials/footer') %>
