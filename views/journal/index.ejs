<%- include('../partials/head') %>
<%- include('../partials/shell-start') %>

<main class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 sm:py-8 lg:px-10">
  <%- include('../partials/flash') %>

  <header class="mb-8 animate-fade-in">
    <h1 class="font-display text-3xl font-bold tracking-tight text-gradient sm:text-4xl">My Journals</h1>
    <p class="mt-2 text-secondary">Browse, search, and manage your entries.</p>
  </header>

  <form action="/journals" method="GET" class="mb-8 animate-fade-in">
    <div class="relative">
      <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="search" name="q" value="<%= search %>"
             placeholder="Search by title, content, or mood..."
             class="input-field w-full rounded-2xl py-3.5 pl-12 pr-4 text-sm">
    </div>
    <% if (search) { %>
      <p class="mt-3 text-sm text-muted">
        Results for &ldquo;<span class="text-secondary"><%= search %></span>&rdquo;
        &middot; <a href="/journals" class="font-medium text-accent hover:text-primary">Clear</a>
      </p>
    <% } %>
  </form>

  <% if (journals.length === 0) { %>
    <section class="panel flex flex-col items-center rounded-3xl px-6 py-20 text-center animate-fade-in">
      <div class="empty-illustration flex h-20 w-20 items-center justify-center rounded-2xl text-4xl ring-1 ring-indigo-500/20">📔</div>
      <h2 class="mt-6 text-xl font-semibold text-primary"><%= search ? 'No matches found' : 'No journals yet' %></h2>
      <p class="mt-2 max-w-sm text-sm text-muted"><%= search ? 'Try a different search term or clear the filter.' : 'Start your journaling journey with your first entry.' %></p>
      <% if (!search) { %>
        <a href="/journals/new" class="btn-primary mt-8 inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold">
          Create first entry
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        </a>
      <% } %>
    </section>
  <% } else { %>
    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 animate-stagger">
      <% journals.forEach(function(j) { %>
        <article class="journal-card panel flex flex-col rounded-2xl p-5">
          <div class="mb-4 flex items-start justify-between gap-2">
            <span class="badge"><%= j.moodMeta.emoji %> <%= j.moodMeta.label %></span>
            <time class="shrink-0 text-xs text-muted"><%= formatRelative(j.updatedAt) %></time>
          </div>
          <h2 class="text-lg font-semibold leading-snug">
            <a href="/journals/<%= j.id %>" class="text-primary transition hover:text-accent"><%= j.title %></a>
          </h2>
          <p class="mt-2 flex-1 line-clamp-3 text-sm leading-relaxed text-muted"><%= j.content %></p>
          <div class="mt-5 flex items-center gap-4 border-t border-white/[0.06] pt-4">
            <a href="/journals/<%= j.id %>" class="text-sm font-medium text-accent hover:text-primary">Read</a>
            <a href="/journals/<%= j.id %>/edit" class="text-sm font-medium text-muted hover:text-secondary">Edit</a>
            <svg class="ml-auto h-4 w-4 text-muted transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        </article>
      <% }); %>
    </section>
  <% } %>
</main>

<%- include('../partials/shell-end') %>
