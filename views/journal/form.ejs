<%- include('../partials/head') %>
<%- include('../partials/shell-start') %>

<main class="mx-auto w-full max-w-2xl flex-1 px-4 py-6 sm:px-6 sm:py-8 lg:px-10">
  <header class="mb-8 animate-fade-in">
    <h1 class="font-display text-3xl font-bold tracking-tight text-gradient sm:text-4xl"><%= pageTitle %></h1>
    <p class="mt-2 text-secondary">Express yourself — title, mood, and reflection.</p>
  </header>

  <% if (errors && errors.length) { %>
    <ul class="flash-toast mb-6 space-y-1 rounded-xl border border-red-500/25 bg-red-500/10 px-4 py-3 text-sm text-red-300">
      <% errors.forEach(function(err) { %><li><%= err %></li><% }); %>
    </ul>
  <% } %>

  <form action="<%= formAction %>" method="POST" class="panel animate-fade-in space-y-6 rounded-2xl p-6 sm:p-8">
    <div>
      <label for="title" class="mb-2 block text-sm font-medium text-secondary">Title</label>
      <input type="text" id="title" name="title" value="<%= title %>" required maxlength="200"
             class="input-field w-full rounded-xl px-4 py-3"
             placeholder="What is on your mind today?">
    </div>

    <div>
      <span class="mb-3 block text-sm font-medium text-secondary">How are you feeling?</span>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        <% moods.forEach(function(m) { %>
          <label class="cursor-pointer">
            <input type="radio" name="mood" value="<%= m.value %>" class="peer sr-only" <%= mood === m.value ? 'checked' : '' %>>
            <span class="flex flex-col items-center gap-1.5 rounded-xl border border-white/[0.08] bg-white/[0.02] px-3 py-4 text-center transition-all duration-200 peer-checked:border-indigo-500/50 peer-checked:bg-indigo-500/10 peer-checked:ring-2 peer-checked:ring-indigo-500/25 peer-checked:scale-[1.02] hover:border-white/[0.14] hover:bg-white/[0.04]">
              <span class="text-2xl"><%= m.emoji %></span>
              <span class="text-sm font-medium text-secondary peer-checked:text-primary"><%= m.label %></span>
            </span>
          </label>
        <% }); %>
      </div>
    </div>

    <div>
      <label for="content" class="mb-2 block text-sm font-medium text-secondary">Journal</label>
      <textarea id="content" name="content" rows="10" required maxlength="10000"
                class="input-field w-full resize-y rounded-xl px-4 py-3 leading-relaxed"
                placeholder="Write your thoughts here..."><%= content %></textarea>
      <p class="mt-2 text-xs text-muted">Up to 10,000 characters</p>
    </div>

    <div class="flex flex-col-reverse gap-3 border-t border-white/[0.06] pt-6 sm:flex-row sm:justify-end">
      <a href="<%= journal ? '/journals/' + journal.id : '/journals' %>" class="btn-secondary inline-flex justify-center rounded-xl px-5 py-2.5 text-sm font-semibold">Cancel</a>
      <button type="submit" class="btn-primary inline-flex justify-center rounded-xl px-5 py-2.5 text-sm font-semibold"><%= submitLabel %></button>
    </div>
  </form>
</main>

<%- include('../partials/shell-end') %>
