<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="mx-auto max-w-2xl px-4 py-8 sm:px-6">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white"><%= pageTitle %></h1>
    <p class="mt-1 text-slate-600 dark:text-slate-400">Express yourself — title, mood, and reflection.</p>
  </header>

  <% if (errors && errors.length) { %>
    <ul class="mb-6 space-y-1 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900 dark:bg-red-950/50 dark:text-red-300">
      <% errors.forEach(function(err) { %><li><%= err %></li><% }); %>
    </ul>
  <% } %>

  <form action="<%= formAction %>" method="POST" class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-8">
    <div>
      <label for="title" class="mb-2 block text-sm font-medium">Title</label>
      <input type="text" id="title" name="title" value="<%= title %>" required maxlength="200"
             class="w-full rounded-xl border border-slate-200 px-4 py-3 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
             placeholder="What is on your mind today?">
    </div>

    <div>
      <span class="mb-3 block text-sm font-medium">How are you feeling?</span>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        <% moods.forEach(function(m) { %>
          <label class="cursor-pointer">
            <input type="radio" name="mood" value="<%= m.value %>" class="peer sr-only" <%= mood === m.value ? 'checked' : '' %>>
            <span class="flex flex-col items-center gap-1 rounded-xl border border-slate-200 bg-slate-50 px-3 py-4 text-center peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:ring-2 peer-checked:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-800 dark:peer-checked:bg-brand-950/50">
              <span class="text-2xl"><%= m.emoji %></span>
              <span class="text-sm font-medium"><%= m.label %></span>
            </span>
          </label>
        <% }); %>
      </div>
    </div>

    <div>
      <label for="content" class="mb-2 block text-sm font-medium">Journal</label>
      <textarea id="content" name="content" rows="10" required maxlength="10000"
                class="w-full resize-y rounded-xl border border-slate-200 px-4 py-3 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                placeholder="Write your thoughts here..."><%= content %></textarea>
    </div>

    <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
      <a href="<%= journal ? '/journals/' + journal.id : '/journals' %>" class="inline-flex justify-center rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold dark:border-slate-700">Cancel</a>
      <button type="submit" class="inline-flex justify-center rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700"><%= submitLabel %></button>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>
