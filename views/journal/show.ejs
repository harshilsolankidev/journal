<%- include('../partials/head') %>
<%- include('../partials/shell-start') %>

<main class="mx-auto w-full max-w-3xl flex-1 px-4 py-6 sm:px-6 sm:py-8 lg:px-10">
  <%- include('../partials/flash') %>

  <article class="panel animate-fade-in overflow-hidden rounded-2xl">
    <header class="relative border-b border-white/[0.06] px-6 py-8 sm:px-10">
      <div class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full bg-indigo-500/15 blur-3xl"></div>
      <div class="relative flex flex-wrap items-center gap-3">
        <span class="badge-accent text-sm">
          <span class="text-base"><%= journal.moodMeta.emoji %></span>
          <%= journal.moodMeta.label %>
        </span>
        <time class="text-sm text-muted">Updated <%= formatDateTime(journal.updatedAt) %></time>
      </div>
      <h1 class="relative mt-5 font-display text-3xl font-bold tracking-tight text-gradient sm:text-4xl"><%= journal.title %></h1>
      <p class="relative mt-2 text-sm text-muted">Created <%= formatDate(journal.createdAt) %></p>
    </header>

    <div class="px-6 py-8 sm:px-10">
      <div class="whitespace-pre-wrap text-base leading-[1.8] text-secondary"><%= journal.content %></div>
    </div>

    <footer class="flex flex-wrap items-center gap-3 border-t border-white/[0.06] px-6 py-5 sm:px-10">
      <a href="/journals/<%= journal.id %>/edit" class="btn-primary inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </a>
      <a href="/journals" class="btn-secondary inline-flex items-center gap-1.5 rounded-xl px-4 py-2.5 text-sm font-medium">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back
      </a>
      <form action="/journals/<%= journal.id %>?_method=DELETE" method="POST" class="ml-auto" onsubmit="return confirm('Delete this entry? This cannot be undone.');">
        <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-red-500/25 bg-red-500/10 px-4 py-2.5 text-sm font-semibold text-red-400 transition hover:border-red-500/40 hover:bg-red-500/15">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        </button>
      </form>
    </footer>
  </article>
</main>

<%- include('../partials/shell-end') %>
