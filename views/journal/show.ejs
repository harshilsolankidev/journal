<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
  <%- include('../partials/flash') %>

  <article class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <header class="border-b border-slate-100 px-6 py-8 dark:border-slate-800 sm:px-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-sm dark:bg-slate-800">
          <span class="text-lg"><%= journal.moodMeta.emoji %></span> <%= journal.moodMeta.label %>
        </span>
        <time class="text-sm text-slate-500">Updated <%= formatDateTime(journal.updatedAt) %></time>
      </div>
      <h1 class="mt-4 text-3xl font-bold text-slate-900 dark:text-white"><%= journal.title %></h1>
      <p class="mt-1 text-sm text-slate-500">Created <%= formatDate(journal.createdAt) %></p>
    </header>

    <div class="px-6 py-8 sm:px-8">
      <div class="whitespace-pre-wrap text-slate-700 dark:text-slate-300"><%= journal.content %></div>
    </div>

    <footer class="flex flex-wrap items-center gap-3 border-t border-slate-100 px-6 py-5 dark:border-slate-800 sm:px-8">
      <a href="/journals/<%= journal.id %>/edit" class="rounded-xl bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">Edit</a>
      <a href="/journals" class="text-sm font-medium text-slate-600 dark:text-slate-400">Back to list</a>
      <form action="/journals/<%= journal.id %>?_method=DELETE" method="POST" class="ml-auto" onsubmit="return confirm('Delete this entry?');">
        <button type="submit" class="rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 dark:border-red-900 dark:text-red-400">Delete</button>
      </form>
    </footer>
  </article>
</main>

<%- include('../partials/footer') %>
